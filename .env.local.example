# ─── Monad Mainnet ────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=143
NEXT_PUBLIC_RPC_URL=https://rpc.monad.xyz/
NEXT_PUBLIC_CHAIN_NAME=Monad

# ─── Contract Addresses (public, safe to expose) ──────────────
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_MARKETPLACE_ADDRESS=
NEXT_PUBLIC_ANAGO_TOKEN=0x5dF178C7E58046BC9074782fef0009C6Be167777

# ─── Pinata IPFS (SERVER-ONLY — do NOT add NEXT_PUBLIC_ prefix!)
# Gateway URL is public, but the API + secret keys must stay server-side.
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# ─── OpenSea API (SERVER-ONLY — used to proxy Monad collection data)
# Free key: https://docs.opensea.io/reference/api-keys
OPENSEA_API_KEY=your_opensea_api_key
